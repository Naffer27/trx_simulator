# ============================================================
# trx_sim — Staging / Production environment template
# Copy to .env and fill in all values before starting services.
# NEVER commit the actual .env file to git.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_ME_50_RANDOM_CHARS

DEBUG=False
APP_NAME=trx_sim

# ── Hosts / Domain ───────────────────────────────────────────
# NOTE: settings.py does NOT read a raw ALLOWED_HOSTS variable — it builds
# ALLOWED_HOSTS from DOMAIN (+ automatic www. subdomain) plus ALLOWED_HOSTS_EXTRA.
# DOMAIN is also used to build SITE_URL-based links and CSRF_TRUSTED_ORIGINS.
DOMAIN=staging.yourdomain.com
SITE_URL=https://staging.yourdomain.com

# Additional hosts beyond DOMAIN (comma-separated). Leave empty if DOMAIN covers it.
# Example: ALLOWED_HOSTS_EXTRA=api.staging.yourdomain.com
ALLOWED_HOSTS_EXTRA=

# Additional CSRF trusted origins beyond DOMAIN (comma-separated, with scheme).
# Example: CSRF_TRUSTED_ORIGINS_EXTRA=https://api.staging.yourdomain.com
CSRF_TRUSTED_ORIGINS_EXTRA=

# Django admin mount point — change to an unpredictable path to obscure it.
# settings.py strips any slashes and re-appends exactly one trailing slash,
# so the value works with or without it.
ADMIN_URL=secure-admin-staging/

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=trx_sim_staging
DB_USER=trx_sim
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_HOST=127.0.0.1
DB_PORT=5432
DB_TEST_NAME=trx_sim_staging_test

# ── Redis ─────────────────────────────────────────────────────
# Use DB index 0 for staging, 1 for a second staging env (if any).
# Format: redis://:password@host:port/db
REDIS_URL=redis://127.0.0.1:6379/0

# ── Logging ───────────────────────────────────────────────────
# Set to true for structured JSON logs (log aggregation, Datadog, etc.)
LOG_JSON=true
SIM_LOG_LEVEL=INFO
SIM_WS_LOG_LEVEL=INFO
SIM_EXP_LOG_LEVEL=WARNING
SIM_RISK_LOG_LEVEL=WARNING

# ── Security ──────────────────────────────────────────────────
# Beta access gate — required at registration when set.
# Set a strong random value. Leave empty for open registration.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
BROKER_ACCESS_CODE=CHANGE_ME_ACCESS_CODE

# ── 2FA ───────────────────────────────────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
TOTP_ISSUER_NAME=Money Broker
# Staging requires 2FA configured/tested for all staff accounts before going live —
# do NOT flip this to True until that verification is done.
TOTP_STAFF_REQUIRED=True

# ── Load Test Bypass ──────────────────────────────────────────
# ONLY enable during active load testing sessions. MUST be False in production.
LOAD_TEST_MODE=False

# ── HTTPS / HSTS ──────────────────────────────────────────────
# Set SECURE_SSL_REDIRECT=True only after Nginx/Certbot HTTPS is verified end-to-end.
# Keep SECURE_HSTS_SECONDS=0 until HTTPS is fully verified — enabling HSTS
# prematurely can lock users out of HTTP permanently.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ── Snapshots ─────────────────────────────────────────────────
SNAPSHOT_RETENTION_DAYS=7

# ── Sentry (optional) ─────────────────────────────────────────
# Leave empty to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
# Inject git SHA from CI: SENTRY_RELEASE=$(git rev-parse --short HEAD)
SENTRY_RELEASE=

# ── Finnhub (live price feed) ─────────────────────────────────
FINNHUB_API_KEY=

# ── Market Data Shadow Mode (FOUNDATION-08, observational only) ─
# Never controls provider selection, prices, or failover — logs
# agreement/disagreement only. Keep False until explicitly approved.
MARKET_DATA_SHADOW_MODE=False

# ── Controlled Provider Router Integration (FOUNDATION-09) ──────
# ENABLED + SYMBOLS controls initial provider selection only for
# allowlisted symbols (comma-separated, e.g. "BTCUSD"). Falls back
# to legacy on any error. Keep False / empty until approved.
MARKET_DATA_ROUTER_ENABLED=False
MARKET_DATA_ROUTER_SYMBOLS=

# ── NowPayments (crypto deposits/withdrawals) ─────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_WEBHOOK_URL=https://staging.yourdomain.com/deposit/callback/
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=

# ── Withdrawal limits ─────────────────────────────────────────
# Reduced from the production default (1500) to keep staging test transactions small.
MAX_WITHDRAWAL_DAILY_USD=100

# ── Email (SMTP) ──────────────────────────────────────────────
# Do NOT use Gmail SMTP for staging/production — low daily limits, flagged as spam.
# SendGrid free tier recommended for staging (see docs/INFRA_PLAN_L1.md section J).
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
ADMIN_EMAIL=your@email.com

# ── Celery Beat ───────────────────────────────────────────────
# These inherit from REDIS_URL — no separate config needed.
# Verify with: celery -A trx_simulator inspect ping

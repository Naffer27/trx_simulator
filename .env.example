# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
#
# Generate DJANGO_SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# Generate TOTP_ENCRYPTION_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate random secrets (IPN, webhook, access code):
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here

DEBUG=False

# Beta access gate — required at registration when set.
# Set to a strong random string to restrict sign-ups to invited users only.
# Leave empty (or unset) to allow open public registration.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
BROKER_ACCESS_CODE=your-access-code-here

# ── Hosts / Domain ───────────────────────────────────────────────────────────
# DOMAIN is added to ALLOWED_HOSTS and must match the public hostname.
# SITE_URL is used in email links — no trailing slash.
# Development: DOMAIN=127.0.0.1  SITE_URL=http://127.0.0.1:8000
# Production:  DOMAIN=yourdomain.com  SITE_URL=https://yourdomain.com
DOMAIN=yourdomain.com
SITE_URL=https://yourdomain.com

# Additional hosts beyond DOMAIN (comma-separated).
# Example: ALLOWED_HOSTS_EXTRA=staging.yourdomain.com,api.yourdomain.com
ALLOWED_HOSTS_EXTRA=

# Additional CSRF trusted origins (comma-separated, with scheme).
# Example: CSRF_TRUSTED_ORIGINS_EXTRA=https://staging.yourdomain.com
CSRF_TRUSTED_ORIGINS_EXTRA=

# Admin interface URL — change to an unpredictable path in production.
# Omit trailing slash; it is added automatically if missing.
# Example: ADMIN_URL=mb-ops-1a2b3c
ADMIN_URL=admin/

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Leave DB_NAME empty to use SQLite in local dev.
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
# Identifies this process in pg_stat_activity — shown in PostgreSQL monitoring.
APP_NAME=trx_sim
# Test database name (defaults to DB_NAME + "_test" if unset).
DB_TEST_NAME=

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for Channels, Celery broker/result backend, and metrics.
# Leave empty to use in-memory fallbacks in local dev.
# Format: redis://:password@host:port/db
REDIS_URL=

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_JSON=true → structured JSON per line (for log aggregation: Datadog, ELK, etc.)
# LOG_JSON=false → human-readable (default for dev)
LOG_JSON=false

# Per-logger level overrides (DEBUG, INFO, WARNING, ERROR, CRITICAL).
# simulator        — broad catch-all for all simulator code
# simulator.ws     — WebSocket consumer events
# simulator.population — population/sim trader engine
# simulator.exposure   — exposure/hedging engine
# simulator.risk       — risk engine guard decisions
SIM_LOG_LEVEL=INFO
SIM_WS_LOG_LEVEL=INFO
SIM_POP_LOG_LEVEL=INFO
SIM_EXP_LOG_LEVEL=WARNING
SIM_RISK_LOG_LEVEL=WARNING

# ── Data Retention ───────────────────────────────────────────────────────────
# Equity snapshots: short-window time-series (default 7 days).
SNAPSHOT_RETENTION_DAYS=7
# Revenue snapshots: longer trend history (default 90 days).
REVENUE_SNAPSHOT_RETENTION_DAYS=90

# ── Rate-limiting bypass ──────────────────────────────────────────────────────
# MUST be False (or unset) in production.
# Setting True disables all rate limiting — only for active load-test sessions.
# WARNING: leaving this True in production is a critical security defect.
LOAD_TEST_MODE=False

# ── HTTPS / HSTS ─────────────────────────────────────────────────────────────
# Set ONLY after HTTPS is verified end-to-end.
# Enabling HSTS prematurely locks users out of HTTP permanently.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ── 2FA (TOTP) ───────────────────────────────────────────────────────────────
# TOTP_ENCRYPTION_KEY must be a Fernet key (32 url-safe base64 bytes).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, TOTP secrets are stored base64-only (dev mode — NOT for production).
TOTP_ENCRYPTION_KEY=
TOTP_ISSUER_NAME=Money Broker
# Set True ONLY after completing 2FA end-to-end testing with all staff accounts.
TOTP_STAFF_REQUIRED=False

# ── Email ────────────────────────────────────────────────────────────────────
#
# DEVELOPMENT (DEBUG=True) — default: filebased backend, emails saved to dev_emails/*.log
#   No SMTP credentials needed. Inspect files to see email content.
#   EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
#   EMAIL_FILE_PATH=/path/to/project/dev_emails
#
# PRODUCTION (DEBUG=False) — use a dedicated transactional provider:
#   SendGrid:   EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
#   Mailgun:    EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
#   Postmark:   EMAIL_BACKEND=anymail.backends.postmark.EmailBackend
#   Amazon SES: EMAIL_BACKEND=anymail.backends.amazon_ses.EmailBackend
#   SMTP:       EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#
# Do NOT use Gmail SMTP for production — low daily limits, flagged as spam.
#
# Leave EMAIL_BACKEND blank to use the auto-selected default:
#   DEBUG=True  → filebased (dev_emails/)
#   DEBUG=False → smtp (EMAIL_HOST_* must be set)
EMAIL_BACKEND=
EMAIL_FILE_PATH=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=server@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ── NowPayments (crypto deposits / withdrawals) ───────────────────────────────
# API key for deposits (NowPayments dashboard → API settings).
NOWPAYMENTS_API_KEY=
# IPN secret — must match the value set in NowPayments → IPN settings.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. If empty, all payment callbacks are rejected.
NOWPAYMENTS_IPN_SECRET=
# Callback URL registered in NowPayments → IPN settings.
NOWPAYMENTS_WEBHOOK_URL=https://yourdomain.com/deposit/callback/
# Email + password used for the NowPayments Payouts JWT auth flow.
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=

# ── Withdrawal limits ─────────────────────────────────────────────────────────
# MAX_WITHDRAWAL_DAILY_USD: maximum USD a user may withdraw in one calendar day
#   (sum of pending + processing + approved + completed withdrawals).
# MIN_WITHDRAWAL_USD: minimum USD per individual withdrawal request.
MAX_WITHDRAWAL_DAILY_USD=1500
MIN_WITHDRAWAL_USD=25

# ── Finnhub (live price feed) ─────────────────────────────────────────────────
FINNHUB_API_KEY=

# ── Market Data Shadow Mode (FOUNDATION-08, observational only) ───────────────
# Evaluates the new SymbolSpec -> InstrumentProfile -> ProviderRoutePlan ->
# ProviderRouter.decide() pipeline alongside the live feed and logs
# agreement/disagreement — never controls provider selection, prices, or
# failover. Keep False until explicitly approved to flip.
MARKET_DATA_SHADOW_MODE=False

# ── Controlled Provider Router Integration (FOUNDATION-09) ────────────────────
# When ENABLED, the new ProviderRouter controls *initial* provider selection,
# but only for symbols on MARKET_DATA_ROUTER_SYMBOLS (comma-separated, e.g.
# "BTCUSD"). Every other symbol keeps running the original legacy logic, and
# any error in the new path falls back to legacy immediately. Keep ENABLED
# False and SYMBOLS empty until explicitly approved to flip. First authorized
# canary: BTCUSD only.
MARKET_DATA_ROUTER_ENABLED=False
MARKET_DATA_ROUTER_SYMBOLS=

# ── Challenge webhooks ────────────────────────────────────────────────────────
# Shared secret for verifying external challenge activation webhooks.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If empty, ALL external webhook requests are rejected.
CHALLENGE_WEBHOOK_SECRET=
# Bearer token for read-only challenge status API requests.
# If empty, ALL status requests are rejected with 401.
CHALLENGE_STATUS_API_TOKEN=

# ── Sentry (optional) ────────────────────────────────────────────────────────
# Leave empty to disable Sentry error tracking.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Inject git SHA from CI/CD: SENTRY_RELEASE=$(git rev-parse --short HEAD)
SENTRY_RELEASE=

# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
#
# Generate DJANGO_SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=your-secret-key-here

DEBUG=False
BROKER_ACCESS_CODE=your-access-code-here

# Rate-limiting bypass — MUST be False (or unset) in production.
# Setting this to True disables all rate limiting, enabling load tests.
# WARNING: leaving this True in production is a critical security defect.
LOAD_TEST_MODE=False

# HTTPS / HSTS — set after HTTPS is verified end-to-end in production.
# Enabling HSTS prematurely will lock users out of HTTP permanently.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Domain / URLs
# DOMAIN is added to ALLOWED_HOSTS and must match the public hostname.
# SITE_URL is used in email links — no trailing slash.
# Development: DOMAIN=127.0.0.1  SITE_URL=http://127.0.0.1:8000
# Production:  DOMAIN=yourdomain.com  SITE_URL=https://yourdomain.com
DOMAIN=yourdomain.com
SITE_URL=https://yourdomain.com

# Admin interface URL — change to an unpredictable path in production.
# Omit trailing slash; it is added automatically if missing.
# Example: ADMIN_URL=mb-ops-1a2b3c
ADMIN_URL=admin/

# Database (leave empty to use SQLite in dev)
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis — used for Channels, Celery broker, and cache (leave empty for in-memory dev defaults)
REDIS_URL=

# NowPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_WEBHOOK_URL=
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=

# Withdrawal limits
# MAX_WITHDRAWAL_DAILY_USD: maximum USD a user may withdraw in one calendar day
#   (sum of pending + processing + approved + completed withdrawals)
# MIN_WITHDRAWAL_USD: minimum USD per individual withdrawal request
MAX_WITHDRAWAL_DAILY_USD=1500
MIN_WITHDRAWAL_USD=25

# Email backend
#
# DEVELOPMENT (DEBUG=True) — default is filebased: emails saved to dev_emails/*.log
#   No Gmail needed. No daily limits. Inspect files to see email content.
#   EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
#   EMAIL_FILE_PATH=/path/to/project/dev_emails
#
# PRODUCTION (DEBUG=False) — NEVER use Gmail SMTP for transactional email.
#   Use a dedicated transactional provider:
#   SendGrid:   EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
#   Mailgun:    EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
#   Postmark:   EMAIL_BACKEND=anymail.backends.postmark.EmailBackend
#   Amazon SES: EMAIL_BACKEND=anymail.backends.amazon_ses.EmailBackend
#
# Leave EMAIL_BACKEND blank to use the auto-selected default:
#   DEBUG=True  → filebased (dev_emails/)
#   DEBUG=False → smtp (configure EMAIL_HOST_* below)
EMAIL_BACKEND=
EMAIL_FILE_PATH=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=server@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# Finnhub
FINNHUB_API_KEY=

# 2FA
# TOTP_ENCRYPTION_KEY must be a Fernet key (32 url-safe base64 bytes).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=
TOTP_ISSUER_NAME=Money Brokers
TOTP_STAFF_REQUIRED=False

# Challenge webhooks
CHALLENGE_WEBHOOK_SECRET=
CHALLENGE_STATUS_API_TOKEN=

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
